[Unit]
Description=REALITY-compatible VLESS server (Rust)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=reality-rs
Group=reality-rs
ExecStart=/usr/local/bin/reality-rs serve /etc/reality-rs/config.json
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/reality-rs
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
